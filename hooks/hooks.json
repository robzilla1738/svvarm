{
  "description": "svvarm hooks — rainbow banner on start, auto-index memories after work",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/post-task.sh",
            "async": true,
            "timeout": 30
          }
        ]
      }
    ]
  }
}
